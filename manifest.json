{
  "manifest_version": 3,
  "name": "Outlook Optimizer",
  "version": "1.0.0",
  "description": "A Chrome extension that improves Outlook with a priority dashboard, urgent email detection, and task extraction.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.cloud.microsoft/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Outlook Optimizer"
  },
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}