{
  "manifest_version": 3,
  "name": "Outlook Email Assistant",
  "version": "1.1.0",
  "description": "A Chrome extension that adds a priority dashboard, urgent email detection, summaries, and task extraction to Outlook Web.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.cloud.microsoft/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Outlook Email Assistant"
  },
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": ["content.js"],
      "css": ["Styles.css"],
      "run_at": "document_idle"
    }
  ]
}
